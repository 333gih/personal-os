# Add to fash-api-gateway Jenkins secret (env-fash-api-gateway-*):

PERSONAL_OS_API_HOST=personal-os-api:8080
# API_SUBDOMAIN_PERSONAL_OS_HOST defaults from PUBLIC_API_DOMAIN in entrypoint.sh

# CORS (global Kong plugin) — allow personal-os FE origin:
# CORS_ALLOWED_ORIGINS=...,https://personal-os-fe.fashandcurious.com
