<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  App Store export for Personal OS (container app + embedded Story Tracker Safari extension).
  CI replaces placeholders in ios-release workflow. See docs/CI-IOS.md
-->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store</string>
	<key>teamID</key>
	<string>TEAM_ID_PLACEHOLDER</string>
	<key>uploadSymbols</key>
	<true/>
	<key>signingStyle</key>
	<string>manual</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>com.personalos.story-tracker</key>
		<string>APP_PROFILE_NAME_PLACEHOLDER</string>
		<key>com.personalos.story-tracker.extension</key>
		<string>EXT_PROFILE_NAME_PLACEHOLDER</string>
	</dict>
	<key>stripSwiftSymbols</key>
	<true/>
</dict>
</plist>
