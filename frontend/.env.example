# =============================================================================
# Personal OS Frontend — environment template
# Copy to `.env.local` for local dev.
# Production: see `.env.prod` / Jenkins secret env-personal-os-{env}
# =============================================================================

# Public site URL (no trailing slash) — SEO, canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Personal OS API (browser calls Kong subdomain in production)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Runtime (Docker / Jenkins)
PORT=3000
NODE_ENV=development
