# =============================================================================
# Personal OS Frontend — environment template
# Copy to `.env.local` or use npm scripts below.
# Production: see `.env.prod` / Jenkins secret env-personal-os-fe-{env}
# =============================================================================

# --- Fash auth BFF (recommended — same pattern as fash-admin-portal-fe) ---
#   npm run dev:prod   → .env.local.prod (fash-auth + prod API proxy)
# Login via fash-auth-service; tokens in httpOnly cookies.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api/v1

API_URL=https://api-auth.fashandcurious.com
AUTH_LOCALE=vi
AUTH_COOKIE_SECURE=false
NEXT_PUBLIC_APP_ID=web
PERSONAL_OS_API_URL=http://localhost:8080

# --- Local full stack (docker compose API without fash-auth) ---
#   cd docker && docker compose up -d
#   Set PERSONAL_OS_API_URL=http://localhost:8080 and AUTH_MODE=local on API

PORT=3000
NODE_ENV=development
