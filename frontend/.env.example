# =============================================================================
# Personal OS Frontend — LOCAL (docker compose / npm run dev:local)
# Copy: cp .env.example .env.local   OR   npm run dev:local
# =============================================================================

NEXT_PUBLIC_SITE_URL=http://localhost:3000
# All environments call production Personal OS API (Kong)
NEXT_PUBLIC_API_URL=https://api-personal-os.fashandcurious.com/api/v1

API_URL=https://api-auth.fashandcurious.com
AUTH_LOCALE=vi
AUTH_COOKIE_SECURE=false

NEXT_PUBLIC_APP_ID=web
COMMERCIAL_APPLICATION_ID=web
INTERNAL_APPLICATION_ID=personal-os-internal

NEXT_PUBLIC_GOOGLE_CLIENT_ID=598587496348-3m7us7ap54ia5clqvag38ctqbuqefasf.apps.googleusercontent.com
NEXT_PUBLIC_ADMIN_PORTAL_URL=https://fashandcurious.com/management/auth/login

# Admin Portal SSO handoff (shared with fash-admin-portal-fe; min 32 chars for local testing)
PERSONAL_OS_SSO_HANDOFF_SECRET=local-dev-sso-handoff-secret-min-32-chars
PERSONAL_OS_SSO_RETURN_URLS=http://localhost:3000/api/auth/internal/callback,https://personal-os-fe.fashandcurious.com/api/auth/internal/callback

INTERNAL_DEFAULT_USER_EMAIL=admin@personal-os.local
INTERNAL_DEFAULT_USER_PASSWORD=changeme123
INTERNAL_DEFAULT_LOGIN_ENABLED=true
NEXT_PUBLIC_INTERNAL_DEFAULT_LOGIN_ENABLED=true

# BFF /api/v1 proxy upstream (same public host)
PERSONAL_OS_API_URL=https://api-personal-os.fashandcurious.com

PORT=3000
NODE_ENV=development
