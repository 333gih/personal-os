INTERNAL_DEFAULT_USER_EMAIL=
INTERNAL_DEFAULT_USER_PASSWORD=
INTERNAL_DEFAULT_LOGIN_ENABLED=false
NEXT_PUBLIC_INTERNAL_DEFAULT_LOGIN_ENABLED=false

# BFF proxies to public Kong host when not on Docker network
