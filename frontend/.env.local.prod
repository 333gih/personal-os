AUTH_COOKIE_SECURE=false

NEXT_PUBLIC_APP_ID=web
COMMERCIAL_APPLICATION_ID=web
INTERNAL_APPLICATION_ID=personal-os-internal

NEXT_PUBLIC_GOOGLE_CLIENT_ID=598587496348-3m7us7ap54ia5clqvag38ctqbuqefasf.apps.googleusercontent.com
