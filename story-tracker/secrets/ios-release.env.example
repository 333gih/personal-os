# Copy to secrets/ios-release.env (gitignored) and fill in values.
# Do NOT commit ios-release.env or binary files (.p12, .mobileprovision, .p8).
#
# Upload to GitHub Actions (repo personal-os):
#   Windows:  .\scripts\push_github_ios_secrets.ps1
#   Mac/Linux: ./scripts/push_github_ios_secrets.sh
#
# Requires: GitHub CLI (`gh auth login`) with repo admin.

# --- Apple Developer (bắt buộc cho iOS Release) ---
APPLE_TEAM_ID=

# Mật khẩu khi export file .p12 (Apple Distribution)
IOS_DISTRIBUTION_CERTIFICATE_PASSWORD=

# App Store provisioning profile — container app (com.personalos.story-tracker)
IOS_PROVISIONING_PROFILE_SPECIFIER=

# App Store provisioning profile — Safari Web Extension (com.personalos.story-tracker.extension)
IOS_EXTENSION_PROVISIONING_PROFILE_SPECIFIER=

# Đường dẫn file (tương đối story-tracker/) — script tự encode base64 lên GitHub
IOS_DISTRIBUTION_CERTIFICATE_PATH=secrets/AppleDistribution.p12
IOS_PROVISIONING_PROFILE_PATH=secrets/Story_Tracker_App_Store.mobileprovision
IOS_EXTENSION_PROVISIONING_PROFILE_PATH=secrets/Story_Tracker_Extension_App_Store.mobileprovision

# Hoặc dán base64 sẵn (bỏ qua PATH nếu dùng):
# IOS_DISTRIBUTION_CERTIFICATE_BASE64=
# IOS_PROVISIONING_PROFILE_BASE64=
# IOS_EXTENSION_PROVISIONING_PROFILE_BASE64=

# --- App Store Connect / TestFlight (tuỳ chọn nhưng khuyến nghị) ---
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_ID=

# Đường dẫn file .p8 — script đọc nội dung multiline
APP_STORE_CONNECT_API_PRIVATE_KEY_PATH=secrets/AuthKey_XXXXXXXXXX.p8

# Hoặc dán nguyên private key (giữ BEGIN/END):
# APP_STORE_CONNECT_API_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
