# Personal OS API (Kong gateway — all data API calls require Bearer token)
API_BASE_URL=https://api-personal-os.fashandcurious.com/api/v1
API_TIMEOUT=30000

# Fash Auth Service (login / refresh / register — separate from Personal OS API)
AUTH_API_URL=https://api-auth.fashandcurious.com
AUTH_LOCALE=vi

# Application IDs registered in fash-auth-service (same pattern as frontend NEXT_PUBLIC_APP_ID)
INTERNAL_APPLICATION_ID=
COMMERCIAL_APPLICATION_ID=

# Personal OS API endpoint paths (relative to API_BASE_URL)
API_READING_PROGRESS=/reading-progress
API_READING_PROGRESS_CURRENT=/reading-progress/current

# Sync defaults (milliseconds)
DEFAULT_SYNC_INTERVAL_MS=30000
