{
  "manifest_version": 3,
  "name": "Story Tracker",
  "version": "1.2.1",
  "description": "Automatically track and sync your reading progress across novel and manga websites.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Story Tracker"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "content_scripts": []
}
