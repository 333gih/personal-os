{
  "name": "story-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Browser extension for tracking reading progress across novel and manga sites",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "node scripts/generate-icons.mjs && npm run build:firefox && npm run build:chrome",
    "build:firefox": "cross-env TARGET=firefox vite build",
    "build:chrome": "cross-env TARGET=chrome vite build",
    "prebuild": "node scripts/generate-icons.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/webextension-polyfill": "^0.12.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-web-extension": "^4.4.0",
    "vitest": "^2.1.0"
  }
}
