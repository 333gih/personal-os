# Personal OS docker compose — local dev
# Production: deploy/jenkins-env.example → Jenkins

APP_ENV=development
APP_PORT=8080
API_PORT=8080
FE_PORT=3000

POSTGRES_USER=personalos
POSTGRES_PASSWORD=personalos
POSTGRES_DB=personalos
POSTGRES_PORT=5433

POSTGRES_DATABASE_HOST=postgres
POSTGRES_DATABASE_PORT=5432
POSTGRES_DATABASE_NAME=personalos
POSTGRES_DATABASE_USER=personalos
POSTGRES_DATABASE_PASSWORD=personalos
POSTGRES_SSL_MODE=disable

JWT_ISSUER=personal-os-api
JWT_SECRET=dev-secret-change-in-production
DEFAULT_USER_EMAIL=admin@personal-os.local
DEFAULT_USER_PASSWORD=changeme123

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI infrastructure (Phase 1-4)
EMBEDDING_WORKER_ENABLED=true
EMBEDDING_WORKER_INTERVAL_SEC=5
EMBEDDING_MAX_ATTEMPTS=5
QDRANT_ENABLED=false
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=personal_context

STORAGE_PROVIDER=
S3_ENDPOINT=seaweedfs-s3:8333
S3_ACCESS_KEY=fash-access-key
S3_SECRET_KEY=change-me-strong-s3-secret
S3_BUCKET=personal-os
S3_USE_SSL=false
S3_PUBLIC_BASE_URL=http://localhost:8333/personal-os
S3_REGION=us-east-1

TRUSTED_PROXIES="127.0.0.1/8,::1/128,172.16.0.0/12"
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
