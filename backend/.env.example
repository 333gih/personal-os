# Personal OS API — local / dev environment
# Copy to .env.prod for production (gitignored) or Jenkins secret file.

APP_ENV=development
APP_PORT=8080
APP_PUBLIC_URL=http://localhost:8080

# PostgreSQL
POSTGRES_DATABASE_HOST=localhost
POSTGRES_DATABASE_PORT=5432
POSTGRES_DATABASE_NAME=personalos
POSTGRES_DATABASE_USER=personalos
POSTGRES_DATABASE_PASSWORD=changeme
POSTGRES_SSL_MODE=disable

# Auth (local mode)
AUTH_MODE=local
JWT_SECRET=dev-secret-change-me
DEFAULT_USER_EMAIL=admin@personal-os.local
DEFAULT_USER_PASSWORD=changeme123

CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# AI — OpenRouter + DeepSeek (recommended for Personal OS)
# Docs: https://openrouter.ai/docs
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Personal OS

# Embeddings via OpenRouter (1536-dim, matches pgvector schema)
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_WORKER_ENABLED=true
EMBEDDING_WORKER_INTERVAL_SEC=5
EMBEDDING_MAX_ATTEMPTS=5

# Optional: Qdrant for hybrid vector search (pgvector still works without it)
QDRANT_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=personal_context

# Legacy aliases (also supported)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=deepseek/deepseek-chat

# Google Calendar integration (optional)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URL=http://localhost:8080/api/v1/integrations/calendar/callback
