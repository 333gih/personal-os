# Copy to secrets/android-release.env (gitignored) and fill values.
# Push to GitHub: .\scripts\push_github_android_secrets.ps1 -Repo owner/personal-os

ANDROID_DEV_ENV_PATH=android/env/dev.env
ANDROID_PROD_ENV_PATH=android/env/prod.env

# Upload keystore for com.personalos.mobile (create in Play Console → App signing)
ANDROID_UPLOAD_KEYSTORE_PATH=secrets/personal-os-upload.keystore
ANDROID_UPLOAD_KEYSTORE_PASSWORD=
ANDROID_UPLOAD_KEY_ALIAS=upload
ANDROID_UPLOAD_KEY_PASSWORD=

# Google Play service account JSON (Play Console → API access)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=secrets/play-service-account.json

# Closed testing track name in Play Console (create track or use internal)
PLAY_TRACK=POS-closed

# Optional: SHA-1 upload key registered on Play (Setup → App signing → Upload key)
PLAY_EXPECTED_UPLOAD_SHA1=
